{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "full_name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "employee", "pending", "rejected"] },
        "companyId": { "type": "string" },
        "phone": { "type": "string" },
        "employeeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Company": {
      "title": "Company",
      "description": "Company in the system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyId": { "type": "string", "description": "4-character unique ID" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "companyId"]
    },
    "Property": {
      "title": "Property",
      "description": "Real estate property listing",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client Name" },
        "governorate": { "type": "string" },
        "area": { "type": "string" },
        "type": { "type": "string" },
        "purpose": { "type": "string" },
        "phone": { "type": "string" },
        "companyId": { "type": "string" },
        "assignedEmployeeId": { "type": "string" },
        "assignedEmployeeName": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "links": { "type": "array", "items": { "type": "string" } },
        "sector": { "type": "string" },
        "block": { "type": "string" },
        "street": { "type": "string" },
        "avenue": { "type": "string" },
        "plotNumber": { "type": "string" },
        "houseNumber": { "type": "string" },
        "location": { "type": "string" },
        "details": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "governorate", "area", "type", "purpose", "phone", "location", "companyId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a property",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "userId", "text", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User's favorite properties",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "userId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for admins",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["new-user", "property-update"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "userId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "companies": {
      "schema": "Company",
      "description": "Collection of companies"
    },
    "properties": {
      "schema": "Property",
      "description": "Collection of property listings"
    },
    "comments": {
      "schema": "Comment",
      "description": "Collection of comments on properties"
    },
    "favorites": {
      "schema": "Favorite",
      "description": "Collection of user favorites"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of system notifications"
    }
  }
}
