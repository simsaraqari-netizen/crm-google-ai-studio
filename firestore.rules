rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "simsaraqari@gmail.com" ||
        request.auth.token.email == "mostafasoliman550@gmail.com" ||
        request.auth.uid == "E94lW4uPsDTePwwq45Dw5ueMni53"
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : {};
    }

    function getCompanyId() {
      return getUserData().companyId;
    }

    function isEmployee() {
      return isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee')
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return (data.email is string && data.email.size() < 100 || !('email' in data)) &&
             (data.role in ['admin', 'employee', 'pending', 'rejected', 'super_admin']) &&
             (data.forceSignOut is bool || !('forceSignOut' in data)) &&
             (data.companyId is string && data.companyId.size() == 4 || !('companyId' in data)) &&
             (data.isDeleted is bool || !('isDeleted' in data)) &&
             (data.deletedAt is string || !('deletedAt' in data)) &&
             (data.employeeId is string && data.employeeId.size() == 4 || !('employeeId' in data));
    }

    function isValidProperty(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.governorate is string && data.governorate.size() < 50 &&
             data.area is string && data.area.size() < 50 &&
             data.type is string && data.type.size() < 50 &&
             data.purpose is string && data.purpose.size() < 50 &&
             (data.phone is string && data.phone.size() < 20 || !('phone' in data)) &&
             data.location is string && data.location.size() < 500 &&
             data.status in ['pending', 'approved', 'rejected', 'deleted'] &&
             data.companyId is string && data.companyId.size() == 4 &&
             (data.assignedEmployeeId is string || !('assignedEmployeeId' in data)) &&
             (data.assignedEmployeeName is string || !('assignedEmployeeName' in data)) &&
             (data.images is list || !('images' in data)) &&
             (data.locationLink is string || !('locationLink' in data)) &&
             (data.isSold is bool || !('isSold' in data)) &&
             (data.sector is string || !('sector' in data)) &&
             (data.block is string || !('block' in data)) &&
             (data.street is string || !('street' in data)) &&
             (data.avenue is string || !('avenue' in data)) &&
             (data.plotNumber is string || !('plotNumber' in data)) &&
             (data.houseNumber is string || !('houseNumber' in data)) &&
             (data.isDeleted is bool || !('isDeleted' in data)) &&
             (data.deletedAt is string || !('deletedAt' in data)) &&
             (data.updatedAt is timestamp || !('updatedAt' in data));
    }

    function isValidComment(data) {
      return data.propertyId is string &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    function isValidCompany(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.companyId is string && data.companyId.size() == 4 &&
             (data.phone is string && data.phone.size() < 20 || !('phone' in data)) &&
             (data.address is string && data.address.size() < 200 || !('address' in data));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /companies/{companyId} {
      allow read: if true;
      allow create, update: if isSuperAdmin() && isValidCompany(request.resource.data) && hasOnlyAllowedFields(['name', 'companyId', 'phone', 'address', 'createdAt']);
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isOwner(userId) || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getCompanyId() == resource.data.companyId));
      allow create: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'pending' && hasOnlyAllowedFields(['email', 'role', 'companyId', 'full_name', 'phone', 'createdAt', 'isDeleted', 'deletedAt', 'employeeId'])) ||
                    (isSuperAdmin() && isValidUser(request.resource.data) && hasOnlyAllowedFields(['email', 'role', 'forceSignOut', 'companyId', 'full_name', 'phone', 'createdAt', 'isDeleted', 'deletedAt', 'employeeId']));
      allow update: if (isSuperAdmin() && hasOnlyAllowedFields(['email', 'role', 'forceSignOut', 'companyId', 'full_name', 'phone', 'createdAt', 'isDeleted', 'deletedAt', 'employeeId'])) || 
                    (isAdmin() && getCompanyId() == resource.data.companyId && request.resource.data.companyId == resource.data.companyId && hasOnlyAllowedFields(['email', 'role', 'forceSignOut', 'companyId', 'full_name', 'phone', 'createdAt', 'isDeleted', 'deletedAt', 'employeeId'])) ||
                    (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.companyId == resource.data.companyId && hasOnlyAllowedFields(['email', 'role', 'forceSignOut', 'companyId', 'full_name', 'phone', 'createdAt', 'isDeleted', 'deletedAt', 'employeeId']) && areImmutableFieldsUnchanged(['createdAt', 'companyId', 'employeeId']));
      allow delete: if isSuperAdmin();
    }

    match /properties/{propertyId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getCompanyId() == resource.data.companyId));
      allow create: if isAuthenticated() && isValidProperty(request.resource.data) && 
                    request.resource.data.status == 'pending' && 
                    request.resource.data.createdBy == request.auth.uid &&
                    (isSuperAdmin() || getCompanyId() == request.resource.data.companyId) &&
                    hasOnlyAllowedFields(['name', 'governorate', 'area', 'type', 'purpose', 'phone', 'location', 'status', 'companyId', 'createdBy', 'createdAt', 'assignedEmployeeId', 'assignedEmployeeName', 'images', 'locationLink', 'isSold', 'sector', 'block', 'street', 'avenue', 'plotNumber', 'houseNumber', 'isDeleted', 'deletedAt', 'updatedAt']);
      allow update: if isAuthenticated() && isValidProperty(request.resource.data) && (
        (isSuperAdmin() || (isAdmin() && getCompanyId() == resource.data.companyId && request.resource.data.companyId == resource.data.companyId)) ||
        (resource.data.createdBy == request.auth.uid && resource.data.status == 'pending' && (request.resource.data.status == 'pending' || request.resource.data.status == 'deleted') && getCompanyId() == request.resource.data.companyId)
      ) && hasOnlyAllowedFields(['name', 'governorate', 'area', 'type', 'purpose', 'phone', 'location', 'status', 'companyId', 'createdBy', 'createdAt', 'assignedEmployeeId', 'assignedEmployeeName', 'images', 'locationLink', 'isSold', 'sector', 'block', 'street', 'avenue', 'plotNumber', 'houseNumber', 'isDeleted', 'deletedAt', 'updatedAt']) && areImmutableFieldsUnchanged(['createdBy', 'createdAt', 'companyId']);
      allow delete: if (isAuthenticated() && (request.auth.token.email == "simsaraqari@gmail.com" || request.auth.token.email == "mostafasoliman550@gmail.com" || request.auth.uid == "E94lW4uPsDTePwwq45Dw5ueMni53")) || 
                    isAdmin() ||
                    (resource.data.createdBy == request.auth.uid && resource.data.status == 'pending');
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /favorites/{favoriteId} {
      allow read, write: if isAuthenticated() && (
        (request.resource != null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && (isAdmin() || resource.data.recipientId == request.auth.uid);
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
